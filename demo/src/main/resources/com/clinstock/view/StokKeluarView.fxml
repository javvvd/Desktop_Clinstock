<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    StokKeluarView.fxml — Halaman Stok Keluar (FEFO).
    Fitur: Form pengeluaran barang + Riwayat stok keluar.
-->
<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinstock.controller.StokKeluarController"
            fitToWidth="true" styleClass="page-scroll"
            stylesheets="@../css/main.css">

    <VBox spacing="20">
        <padding>
            <Insets top="8" bottom="20" left="4" right="4"/>
        </padding>

        <!-- Page Title -->
        <VBox spacing="4">
            <Label text="Stok Keluar" styleClass="page-title"/>
            <Label text="Keluarkan stok menggunakan sistem FEFO (First Expired, First Out)."
                   styleClass="page-subtitle"/>
        </VBox>

        <!-- ====== FORM STOK KELUAR ====== -->
        <VBox styleClass="form-container" spacing="16">
            <Label text="Form Pengeluaran Barang" styleClass="section-title"/>

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    <ColumnConstraints prefWidth="320" hgrow="ALWAYS"/>
                    <ColumnConstraints prefWidth="160"/>
                </columnConstraints>

                <!-- Row 0: Item -->
                <Label text="Item / Barang" styleClass="form-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="comboItem" styleClass="form-combo" prefWidth="320"
                          promptText="Pilih item..."
                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label fx:id="lblAvailableStock" text="Stok tersedia: -"
                       styleClass="form-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="2"/>

                <!-- Row 1: Quantity -->
                <Label text="Jumlah Keluar" styleClass="form-label"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtQuantity" styleClass="form-field"
                           promptText="Masukkan jumlah"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <!-- Row 2: Destination -->
                <Label text="Tujuan" styleClass="form-label"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtDestination" styleClass="form-field"
                           promptText="Contoh: Poli Umum, Ruang IGD"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <!-- Row 3: Notes -->
                <Label text="Catatan" styleClass="form-label"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextArea fx:id="txtNotes" styleClass="form-field"
                          promptText="Catatan tambahan (opsional)"
                          prefRowCount="2"
                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>

            <!-- FEFO Info -->
            <Label text="Sistem akan otomatis mengeluarkan stok dari batch dengan tanggal kadaluarsa terdekat (FEFO — First Expired, First Out)."
                   styleClass="page-subtitle" wrapText="true"/>

            <!-- Status + Button -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="Proses Keluar" styleClass="btn-primary" onAction="#handleProcess"/>
                <Button text="Reset" styleClass="btn-secondary" onAction="#handleReset"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text="" styleClass="status-label"/>
            </HBox>
        </VBox>

        <!-- ====== RIWAYAT STOK KELUAR ====== -->
        <VBox spacing="10">
            <Label text="Riwayat Stok Keluar" styleClass="section-title"/>
            <TableView fx:id="tableStockOut" styleClass="data-table" prefHeight="250">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colDate" text="Tanggal" prefWidth="140"/>
                    <TableColumn fx:id="colItem" text="Item" prefWidth="180"/>
                    <TableColumn fx:id="colBatch" text="Batch (FEFO)" prefWidth="140"/>
                    <TableColumn fx:id="colQty" text="Qty" prefWidth="70"/>
                    <TableColumn fx:id="colDestination" text="Tujuan" prefWidth="150"/>
                    <TableColumn fx:id="colNotes" text="Catatan" prefWidth="150"/>
                    <TableColumn fx:id="colAction" text="Aksi" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Belum ada riwayat stok keluar." styleClass="page-subtitle"/>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>
