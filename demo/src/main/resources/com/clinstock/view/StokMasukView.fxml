<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    StokMasukView.fxml — Halaman Stok Masuk.
    Fitur: Form input barang masuk (batch, expired, qty) + Riwayat.
-->
<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinstock.controller.StokMasukController"
            fitToWidth="true" styleClass="page-scroll"
            stylesheets="@../css/main.css">

    <VBox spacing="20">
        <padding>
            <Insets top="8" bottom="20" left="4" right="4"/>
        </padding>

        <!-- Page Title -->
        <VBox spacing="4">
            <Label text="Stok Masuk" styleClass="page-title"/>
            <Label text="Catat pemasukan barang ke inventori klinik." styleClass="page-subtitle"/>
        </VBox>

        <!-- ====== FORM STOK MASUK ====== -->
        <VBox styleClass="form-container" spacing="16">
            <Label text="Form Input Barang Masuk" styleClass="section-title"/>

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    <ColumnConstraints prefWidth="320" hgrow="ALWAYS"/>
                </columnConstraints>

                <!-- Row 0: Item -->
                <Label text="Item / Barang" styleClass="form-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="comboItem" styleClass="form-combo" prefWidth="320"
                          promptText="Pilih item..."
                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <!-- Row 1: Batch Number -->
                <Label text="Nomor Batch" styleClass="form-label"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtBatch" styleClass="form-field"
                           promptText="Contoh: BATCH-2026-001"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <!-- Row 2: Expired Date -->
                <Label text="Tanggal Kadaluarsa" styleClass="form-label"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dateExpired" styleClass="form-date" prefWidth="320"
                            GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <!-- Row 3: Quantity -->
                <Label text="Jumlah (Qty)" styleClass="form-label"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtQuantity" styleClass="form-field"
                           promptText="Masukkan jumlah"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <!-- Row 4: Supplier -->
                <Label text="Supplier" styleClass="form-label"
                       GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="txtSupplier" styleClass="form-field"
                           promptText="Nama supplier (opsional)"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <!-- Row 5: Notes -->
                <Label text="Catatan" styleClass="form-label"
                       GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextArea fx:id="txtNotes" styleClass="form-field"
                          promptText="Catatan tambahan (opsional)"
                          prefRowCount="2"
                          GridPane.rowIndex="5" GridPane.columnIndex="1"/>
            </GridPane>

            <!-- Status + Button -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="Simpan Stok Masuk" styleClass="btn-primary" onAction="#handleSave"/>
                <Button text="Reset" styleClass="btn-secondary" onAction="#handleReset"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text="" styleClass="status-label"/>
            </HBox>
        </VBox>

        <!-- ====== RIWAYAT STOK MASUK ====== -->
        <VBox spacing="10">
            <Label text="Riwayat Stok Masuk" styleClass="section-title"/>
            <TableView fx:id="tableStockIn" styleClass="data-table" prefHeight="250">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colDate" text="Tanggal" prefWidth="140"/>
                    <TableColumn fx:id="colItem" text="Item" prefWidth="180"/>
                    <TableColumn fx:id="colBatch" text="Batch" prefWidth="140"/>
                    <TableColumn fx:id="colQty" text="Qty" prefWidth="50"/>
                    <TableColumn fx:id="colRemaining" text="Sisa" prefWidth="50"/>
                    <TableColumn fx:id="colExpired" text="Kadaluarsa" prefWidth="110"/>
                    <TableColumn fx:id="colSupplier" text="Supplier" prefWidth="120"/>
                    <TableColumn fx:id="colAction" text="Aksi" prefWidth="80"/>
                </columns>
                <placeholder>
                    <Label text="Belum ada riwayat stok masuk." styleClass="page-subtitle"/>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>
