<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
    DashboardView.fxml — Halaman Dashboard Interaktif.
    Menampilkan: ringkasan stok, grafik, dan panel notifikasi.
-->
<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinstock.controller.DashboardController"
            fitToWidth="true" styleClass="page-scroll"
            stylesheets="@../css/main.css">

    <VBox spacing="20">
        <padding>
            <Insets top="8" bottom="20" left="4" right="4"/>
        </padding>

        <!-- Welcome Message -->
        <VBox spacing="4">
            <Label fx:id="lblWelcome" text="Selamat Datang" styleClass="page-title"/>
            <Label fx:id="lblWelcomeSub" text="Berikut ringkasan kondisi inventori klinik Anda."
                   styleClass="page-subtitle"/>
        </VBox>

        <!-- ====== SUMMARY CARDS ROW ====== -->
        <HBox spacing="14">
            <!-- Card: Stok Menipis -->
            <VBox styleClass="summary-card,summary-card-warn" spacing="4" HBox.hgrow="ALWAYS">
                <Label text="STOK MENIPIS" styleClass="card-title"/>
                <Label fx:id="lblLowStock" text="0" styleClass="card-value,card-value-warn"/>
                <Label text="item di bawah minimum" styleClass="card-title"/>
            </VBox>

            <!-- Card: Kadaluarsa -->
            <VBox styleClass="summary-card,summary-card-danger" spacing="4" HBox.hgrow="ALWAYS">
                <Label text="KADALUARSA" styleClass="card-title"/>
                <Label fx:id="lblExpiring" text="0" styleClass="card-value,card-value-danger"/>
                <Label text="batch perlu perhatian" styleClass="card-title"/>
            </VBox>

            <!-- Card: Mendekati Kadaluarsa -->
            <VBox styleClass="summary-card,summary-card-info" spacing="4" HBox.hgrow="ALWAYS">
                <Label text="MENDEKATI KADALUARSA" styleClass="card-title"/>
                <Label fx:id="lblExpiringThreeMonths" text="0" styleClass="card-value,card-value-info"/>
                <Label text="batch dalam 3 bulan" styleClass="card-title"/>
            </VBox>

            <!-- Card: Total Stok -->
            <VBox styleClass="summary-card,summary-card-success" spacing="4" HBox.hgrow="ALWAYS">
                <Label text="TOTAL STOK" styleClass="card-title"/>
                <Label fx:id="lblTotalStock" text="0" styleClass="card-value,card-value-success"/>
                <Label text="unit tersedia" styleClass="card-title"/>
            </VBox>
        </HBox>

        <!-- ====== CHARTS ROW ====== -->
        <HBox spacing="14">
            <!-- PieChart: Distribusi Stok per Kategori -->
            <VBox styleClass="chart-container" spacing="4" HBox.hgrow="ALWAYS">
                <PieChart fx:id="pieChartCategory" title="Distribusi Stok per Kategori"
                          styleClass="chart-area" prefHeight="280" animated="true"
                          legendSide="BOTTOM"/>
            </VBox>

            <!-- BarChart: Pergerakan Stok Bulanan -->
            <VBox styleClass="chart-container" spacing="4" HBox.hgrow="ALWAYS">
                <BarChart fx:id="barChartMonthly" title="Pergerakan Stok (6 Bulan Terakhir)"
                          styleClass="chart-area" prefHeight="280" animated="true"
                          legendSide="BOTTOM" barGap="2" categoryGap="20">
                    <xAxis><CategoryAxis label="Bulan"/></xAxis>
                    <yAxis><NumberAxis label="Jumlah"/></yAxis>
                </BarChart>
            </VBox>
        </HBox>

        <!-- ====== NOTIFICATION PANEL ====== -->
        <VBox styleClass="notification-panel" spacing="10">
            <Label text="Panel Notifikasi — Peringatan Dini" styleClass="notif-title"/>
            <TableView fx:id="tableNotifications" styleClass="notif-table"
                       prefHeight="200">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colNotifType" text="Tipe" prefWidth="140"/>
                    <TableColumn fx:id="colNotifItem" text="Item" prefWidth="200"/>
                    <TableColumn fx:id="colNotifDetail" text="Detail" prefWidth="320"/>
                    <TableColumn fx:id="colNotifStatus" text="Status" prefWidth="180"/>
                </columns>
                <placeholder>
                    <Label text="✅ Tidak ada peringatan saat ini." styleClass="page-subtitle"/>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>
